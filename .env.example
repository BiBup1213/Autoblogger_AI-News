# Local persistence
DATABASE_PATH=data/autoblogger.sqlite3

# HTTP behavior
HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT=AutobloggerAI-News/0.1 (+https://example.com; contact@example.com)
MAX_ARTICLES_PER_RUN=20
# Prevent one source from consuming the whole run. Must be a positive integer.
MAX_ARTICLES_PER_SOURCE_PER_RUN=5
MIN_EXTRACTED_CHARS=500

# Summarization
# Use "stub" for local smoke tests. OPENAI_API_KEY is required only when
# SUMMARIZER_PROVIDER=openai.
SUMMARIZER_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_INPUT_CHARS=30000
OPENAI_REQUEST_TIMEOUT_SECONDS=60

# Optional OpenAI image generation for WordPress featured images.
# Disabled by default. Reuses OPENAI_API_KEY when IMAGE_PROVIDER=openai.
# Generated images are editorial illustrations; review them before publishing.
IMAGE_GENERATION_ENABLED=false
IMAGE_PROVIDER=openai
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_STYLE=editorial
OPENAI_IMAGE_TIMEOUT_SECONDS=90
OPENAI_IMAGE_PROMPT_MAX_CHARS=4000
# If false, images are saved to a temporary local path only for upload.
OPENAI_IMAGE_SAVE_LOCAL_COPY=false
OPENAI_IMAGE_OUTPUT_DIR=data/generated_images

# WordPress REST API
# Draft creation is skipped while WP_DRY_RUN=true.
WP_DRY_RUN=true
# Default is draft for safety. Use publish only when ready for live publishing.
WP_POST_STATUS=draft
WP_BASE_URL=https://your-wordpress-site.example
WP_USERNAME=your-wordpress-username
WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional existing numeric WordPress IDs.
# Category and tag IDs must already exist in WordPress. This app does not create them.
WP_DEFAULT_CATEGORY_ID=
WP_TAG_IDS=

# Optional AI-assisted WordPress category selection.
# Category names may be German. The model may use their semantic meaning, but it
# must return only predefined numeric IDs. Categories are never created automatically.
AI_CATEGORY_CLASSIFICATION_ENABLED=false
AI_ALLOWED_CATEGORIES=
# Example:
# AI_ALLOWED_CATEGORIES=5:KI-News,6:Modelle,7:Forschung,8:Tools,9:Sicherheit,10:Audio & Video,11:Robotik,12:Unternehmen,13:Open Source,14:Regulierung
